<!-- AIRFLOW LOGIC -->
<script>
let rooms = [];
function addRoom() {
  rooms.push({ name: 'New Room', sqft: 150, regs: 1 });
  renderRooms();
}
function deleteRoom(idx) { rooms.splice(idx, 1); renderRooms(); }
function updateRoom(idx, key, val) { 
  rooms[idx][key] = val; 
  recalcAll(); 
}
function renderRooms() {
  const tbody = document.getElementById('roomTbody');
  tbody.innerHTML = '';
  rooms.forEach((r, i) => {
    tbody.innerHTML += `<tr>
      <td><input type="text" value="${r.name}" oninput="updateRoom(${i}, 'name', this.value)" style="width:100%;"></td>
      <td><input type="number" value="${r.sqft}" oninput="updateRoom(${i}, 'sqft', parseFloat(this.value)||0)" style="width:80px;"></td>
      <td id="cfm_${i}">тАФ</td>
      <td><input type="number" value="${r.regs}" oninput="updateRoom(${i}, 'regs', parseInt(this.value)||1)" style="width:50px;"></td>
      <td id="cfmReg_${i}">тАФ</td>
      <td><button onclick="deleteRoom(${i})" style="color: var(--fail);">├Ч</button></td>
    </tr>`;
  });
  recalcAll();
}
function clearRooms() { rooms = []; renderRooms(); }

function recalcAll() {
  const factor = parseFloat(document.getElementById('cfm_method').value);
  let totalCFM = 0;
  let totalRegs = 0;
  rooms.forEach((r, i) => {
    const cfm = r.sqft * factor;
    totalCFM += cfm;
    totalRegs += r.regs;
    const cfmEl = document.getElementById('cfm_' + i);
    const cfmRegEl = document.getElementById('cfmReg_' + i);
    if (cfmEl) cfmEl.innerText = Math.ceil(cfm);
    if (cfmRegEl) cfmRegEl.innerText = Math.ceil(cfm / r.regs);
  });
  document.getElementById('footTotalCFM').innerText = Math.ceil(totalCFM);
  document.getElementById('footTotalRegs').innerText = totalRegs;
  document.getElementById('res_total_cfm').innerText = Math.ceil(totalCFM) + ' CFM';
  
  const tons = parseFloat(document.getElementById('sys_tons').value);
  if (tons > 0) {
    const target = tons * 400;
    const diff = totalCFM - target;
    const status = Math.abs(diff) < 100 ? 'тЬФ BALANCED' : (diff > 0 ? 'тЪа OVERSUPPLIED' : 'тЪа UNDERSUPPLIED');
    document.getElementById('res_status').innerText = status;
  }
  
  if (window.updateMintStickyBar) { window.updateMintStickyBar({ 'Total Flow': Math.ceil(totalCFM) + ' CFM', 'Rooms': rooms.length }, '/hvac-cfm-calculator/'); }
}
renderRooms();
</script>

