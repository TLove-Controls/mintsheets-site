<!-- LABOR LOGIC -->
<script>
function recalc() {
  const wage = parseFloat(document.getElementById('baseWage').value) || 0;
  const burden = (parseFloat(document.getElementById('burdenPct').value) || 0) / 100;
  const hours = parseFloat(document.getElementById('projHours').value) || 0;
  const techs = parseFloat(document.getElementById('numTechs').value) || 1;
  
  const bAmt = wage * burden;
  const bRate = wage + bAmt;
  const totalCost = bRate * hours * techs;
  
  document.getElementById('burdenedRate').innerText = '$' + bRate.toFixed(2) + '/hr';
  document.getElementById('burdenAmt').innerText = '$' + bAmt.toFixed(2) + '/hr';
  document.getElementById('projCost').innerText = '$' + Math.round(totalCost).toLocaleString();
  
  if (window.updateMintStickyBar) { window.updateMintStickyBar({ 'Labor Cost': '$' + Math.round(totalCost).toLocaleString(), 'Hours': hours * techs }, '/hvac-profit-margin-calculator/'); }
}
recalc();
</script>

<!-- NAVIGATION SCRIPT -->
  <script>
  (function () {
    var btn = document.getElementById('hamburger-btn');
    var nav = document.getElementById('mobile-nav');
    var overlay = document.getElementById('mobile-nav-overlay');
    var close = document.getElementById('mobile-nav-close');
    if (!btn || !nav) return;
    function setMenuState(open) {
      document.body.classList.toggle('menu-open', open);
      btn.classList.toggle('active', open);
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      nav.setAttribute('aria-hidden', open ? 'false' : 'true');
    }
    btn.addEventListener('click', function () { setMenuState(!btn.classList.contains('active')); });
    close && close.addEventListener('click', function () { setMenuState(false); });
    overlay && overlay.addEventListener('click', function () { setMenuState(false); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') setMenuState(false);
    });
  })();
  </script>

