/small></div>\r","      <ul class=\"tier-features\">\r","        <li>Base system (14.3 SEER2)</li>\r","        <li>Standard 1-yr parts &amp; labor</li>\r","        <li>Basic digital thermostat</li>\r","        <li>Standard installation</li>\r","      </ul>\r","    </div>\r","    <div class=\"tier-card\">\r","      <div class=\"tier-header\">🥈 BETTER</div>\r","      <div class=\"tier-price\" id=\"t-better\">$0<small>Mid Efficiency (+8%)</small></div>\r","      <ul class=\"tier-features\">\r","        <li>16 SEER2 system</li>\r","        <li>2-yr parts &amp; labor warranty</li>\r","        <li>Smart thermostat included</li>\r","        <li>Premium air filter</li>\r","      </ul>\r","    </div>\r","    <div class=\"tier-card best\">\r","      <div class=\"tier-header\">🥇 BEST</div>\r","      <div class=\"tier-price\" id=\"t-best\">$0<small>High Efficiency (+18%)</small></div>\r","      <ul class=\"tier-features\">\r","        <li>18+ SEER2 system</li>\r","        <li>5-yr parts &amp; labor warranty</li>\r","        <li>Smart thermostat + zoning</li>\r","        <li>UV air purifier included</li>\r","        <li>Annual tune-up included</li>\r","      </ul>\r","    </div>\r","  </div>\r","\r","  <div class=\"divider\"></div>\r","\r","  <!-- ═══════════════════════════════════════════════════════ -->\r","  <!-- SECTION 6: TRACKING LOG -->\r","  <!-- ═══════════════════════════════════════════════════════ -->\r","  \r","    <!-- Ad Placeholder: Above Calculator -->\r","    <div class=\"ad-placeholder ad-placeholder-tool\">\r","      <span>Advertisement</span>\r","    </div>\r","\r","\r","    <span class=\"icon\">📝</span> SECTION 6 — BID TRACKING &amp; FOLLOW-UP LOG\r","  </div>\r","  <div class=\"content\" style=\"padding-bottom: 0;\">\r","    <div class=\"table-scroll\">\r","    <table class=\"line-table\" style=\"font-size:12px;\">\r","      <thead>\r","        <tr>\r","          <th>Customer</th>\r","          <th>Est. #</th>\r","          <th>Date</th>\r","          <th>Bid Amount</th>\r","          <th>Follow-Up</th>\r","          <th>Status</th>\r","          <th class=\"no-print\">Action</th>\r","        </tr>\r","      </thead>\r","      <tbody id=\"logBody\">\r","        <tr style=\"color:var(--muted);font-style:italic;\">\r","          <td colspan=\"7\" style=\"text-align:center;padding:12px;\">\r","            No bids logged yet — click \"Save to Log\" to add this bid.\r","          </td>\r","        </tr>\r","      </tbody>\r","    </table>\r","    </div>\r","    <div class=\"spacer\"></div>\r","  </div>\r","\r","  <!-- PRO TIPS -->\r","  <div class=\"tips-box\">\r","    <strong>⚡ Pro Tips for Winning More Bids</strong><br>\r","    Always present all three tiers in person — 60% of customers choose Better or Best when offered. · Lead with financing options to shift the conversation from price to monthly payment. · Include a photo of the old unit in the proposal to justify the replacement. · Follow up within 24 hours — bid acceptance drops by 40% after 3 days.\r","  </div>\r","\r","  <!-- ACTION ROW -->\r","  <div class=\"btn-row no-print\" style=\"justify-content: space-between; align-items: center;\">\r","    <div style=\"display:flex;gap:10px;flex-wrap:wrap;\">\r","      <button class=\"btn btn-primary\" onclick=\"saveBid()\">💾 Save to Log</button>\r","      <button class=\"btn btn-orange\" onclick=\"window.print()\">🖨️ Print / Save PDF</button>\r","      <button class=\"btn btn-steel\" onclick=\"clearAll()\">🗑️ Clear All</button>\r","    </div>\r","    <div style=\"font-size:12px;color:var(--muted);\">\r","      Margin: <strong id=\"footer-margin\" style=\"color:var(--primary);\">30%</strong> &nbsp;|&nbsp;\r","      Total: <strong id=\"footer-total\" style=\"color:var(--accent);\">$0.00</strong>\r","    </div>\r","  </div>\r","\r","        </div>\r","      </section>\r","    </main>\r","\r","        <!-- Ad Placeholder: Bottom Banner -->\r","    <div class=\"ad-placeholder ad-placeholder-bottom\">\r","      <span>Advertisement</span>\r","    </div>\r","\r","<div class=\"workflow-chain\">\r","        <div class=\"workflow-title\"><span>🔄</span> Professional Workflow Navigation</div>\r","        <div class=\"workflow-steps\">\r","            <a href=\"/hvac-load-calculator/\" class=\"workflow-step\">1. Load Calc</a>\r","            <span class=\"workflow-arrow\">&rarr;</span>\r","            <a href=\"/hvac-cfm-calculator/\" class=\"workflow-step\">2. Airflow</a>\r","            <span class=\"workflow-arrow\">&rarr;</span>\r","            <a href=\"/hvac-duct-size-calculator/\" class=\"workflow-step\">3. Duct Sizing</a>\r","            <span class=\"workflow-arrow\">&rarr;</span>\r","            <a href=\"/hvac-static-pressure-calculator/\" class=\"workflow-step\">4. Static Pressure</a>\r","            <span class=\"workflow-arrow\">&rarr;</span>\r","            <a href=\"/hvac-bid-calculator/\" class=\"workflow-step active\">5. Bid Tool</a>\r","        </div>\r","    </div>\r","\r","        <!-- Ad Placeholder: Bottom Banner -->","    <div class=\"ad-placeholder ad-placeholder-bottom\">","      <span>Advertisement</span>","    </div>","","<footer id=\"mint-footer\" style=\"background: var(--panel-elevated); border-top: 1px solid var(--line); padding: 40px 0; margin-top: 60px; font-family: sans-serif; clear: both;\">\r","      <div style=\"max-width: 1100px; margin: 0 auto; padding: 0 20px;\">\r","        <h3 style=\"color: var(--primary); font-weight: 900; font-size: 18px; text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1px;\">Related HVAC Calculators</h3>\r","        <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;\">\r","          <a href=\"/hvac-flow-rate-calculator/\" style=\"color: var(--muted); text-decoration: none; font-size: 14px;\">Flow Rate Calculator</a>\r","          <a href=\"/hvac-load-calculator/\" style=\"color: var(--muted); text-decoration: none; font-size: 14px;\">Load Calculator</a>\r","          <a href=\"/hvac-service-price-calculator/\" style=\"color: var(--muted); text-decoration: none; font-size: 14px;\">Service Price Calculator</a>\r","          <a href=\"/hvac-duct-size-calculator/\" style=\"color: var(--muted); text-decoration: none; font-size: 14px;\">Duct Size Calculator</a>\r","        </div>\r","        <div style=\"display:flex;justify-content:center;flex-wrap:wrap;gap:10px;margin-top:20px;font-size:14px;\">\r","          <a href=\"/privacy-policy/\" style=\"color:var(--muted);\">Privacy Policy</a> |\r","          <a href=\"/terms-of-service/\" style=\"color:var(--muted);\">Terms of Service</a> |\r","          <a href=\"/disclaimer/\" style=\"color:var(--muted);\">Disclaimer</a> |\r","          <a href=\"/cookie-policy/\" style=\"color:var(--muted);\">Cookie Policy</a>\r","        </div>\r","        \r","        <div style=\"margin-top: 25px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px; color: var(--muted); font-size: 13px; display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;\">\r","            <span><span style=\"color: var(--primary);\">✔</span> Used by HVAC technicians & contractors</span>\r","            <span><span style=\"color: var(--primary);\">✔</span> Based on ACCA Manual standards</span>\r","            <span><span style=\"color: var(--primary);\">✔</span> Free professional tools</span>\r","        </div>\r","    <p style=\"margin-top: 20px; color: var(--muted); font-size: 12px;\">&copy; 2026 MintSheets. Free HVAC technical tools.</p>\r","      </div>\r","    </footer>\r","\r","    <!-- RESTORED BID CALCULATOR LOGIC -->\r","    <script>\r","        document.addEventListener('DOMContentLoaded', function() {\r","            addRow('material');\r","            addRow('labor');\r","            recalc();\r","        });\r","\r","        function addRow(type) {\r","            const body = document.getElementById(type + 'Body');\r","            const row = document.createElement('tr');\r","            if (type === 'material') {\r","                row.innerHTML = `\r","                    <td><input type=\"text\" placeholder=\"Equipment/Part description\" style=\"width:100%\"></td>\r","                    <td><input type=\"number\" class=\"mat-qty\" value=\"1\" oninput=\"recalc()\" style=\"width:100%\"></td>\r","                    <td><input type=\"number\" class=\"mat-cost\" value=\"0\" oninput=\"recalc()\" style=\"width:100%\"></td>\r","                    <td class=\"mat-ext\">$0.00</td>\r","                    <td><select style=\"width:100%\"><option>Equip</option><option>Part</option><option>Misc</option></select></td>\r","                    <td class=\"no-print\"><button class=\"btn btn-delete btn-sm\" onclick=\"this.closest('tr').remove();recalc();\">✕</button></td>\r","                `;\r","            } else {\r","                row.innerHTML = `\r","                    <td><input type=\"text\" placeholder=\"Labor Task\" style=\"width:100%\"></td>\r","                    <td><input type=\"number\" class=\"lab-hours\" value=\"1\" oninput=\"recalc()\" style=\"width:100%\"></td>\r","                    <td><input type=\"number\" class=\"lab-rate\" value=\"45\" oninput=\"recalc()\" style=\"width:100%\"></td>\r","                    <td class=\"lab-ext\">$45.00</td>\r","                    <td><select style=\"width:100%\"><option>Install</option><option>Service</option><option>Other</option></select></td>\r","                    <td class=\"no-print\"><button class=\"btn btn-delete btn-sm\" onclick=\"this.closest('tr').remove();recalc();\">✕</button></td>\r","                `;\r","            }\r","            body.appendChild(row);\r","            recalc();\r","        }\r","\r","        function updateMargin() {\r","            const val = document.getElementById('marginSlider').value;\r","            document.getElementById('marginBadge').innerText = val + '%';\r","            document.getElementById('footer-margin').innerText = val + '%';\r","            document.getElementById('s-mkpct').innerText = val;\r","            recalc();\r","        }\r","\r","        function recalc() {\r","            let matTotal = 0;\r","            document.querySelectorAll('#materialBody tr').forEach(row => {\r","                const qtyInput = row.querySelector('.mat-qty');\r","                const costInput = row.querySelector('.mat-cost');\r","                if (!qtyInput || !costInput) return;\r","                const qty = parseFloat(qtyInput.value) || 0;\r","                const cost = parseFloat(costInput.value) || 0;\r","                const ext = qty * cost;\r","                row.querySelector('.mat-ext').innerText = '$' + ext.toFixed(2);\r","                matTotal += ext;\r","            });\r","            document.getElementById('matTotal').innerText = '$' + matTotal.toFixed(2);\r","\r","            let laborTotal = 0;\r","            document.querySelectorAll('#laborBody tr').forEach(row => {\r","                const hoursInput = row.querySelector('.lab-hours');\r","                const rateInput = row.querySelector('.lab-rate');\r","                if (!hoursInput || !rateInput) return;\r","                const hours = parseFloat(hoursInput.value) || 0;\r","                const rate = parseFloat(rateInput.value) || 0;\r","                const ext = hours * rate;\r","                row.querySelector('.lab-ext').innerText = '$' + ext.toFixed(2);\r","                laborTotal += ext;\r","            });\r","            document.getElementById('laborTotal').innerText = '$' + laborTotal.toFixed(2);\r","\r","            const refLbs = parseFloat(document.getElementById('refLbs').value) || 0;\r","            const refRate = parseFloat(document.getElementById('refRate').value) || 0;\r","            const refTotal = refLbs * refRate;\r","\r","            const permit = parseFloat(document.getElementById('permitFee').value) || 0;\r","            const disposal = parseFloat(document.getElementById('disposalFee').value) || 0;\r","            const rawCost = matTotal + laborTotal + refTotal + permit + disposal;\r","\r","            const marginPct = parseFloat(document.getElementById('marginSlider').value) || 0;\r","            const marginMultiplier = (marginPct >= 100) ? 100 : (1 - (marginPct / 100));\r","            const sellPriceBeforeDisc = rawCost / marginMultiplier;\r","            const markup = sellPriceBeforeDisc - rawCost;\r","\r","            const discount = parseFloat(document.getElementById('discount').value) || 0;\r","            const finPct = parseFloat(document.getElementById('financing').value) || 0;\r","            const finFee = (sellPriceBeforeDisc - discount) * (finPct / 100);\r","\r","            const taxRate = parseFloat(document.getElementById('taxRate').value) || 0;\r","            const taxable = Math.max(0, sellPriceBeforeDisc - discount + finFee);\r","            const tax = taxable * (taxRate / 100);\r","\r","            const totalBid = taxable + tax;\r","\r","            // Summary\r","            document.getElementById('s-mat').innerText = '$' + matTotal.toFixed(2);\r","            document.getElementById('s-lab').innerText = '$' + laborTotal.toFixed(2);\r","            document.getElementById('s-ref').innerText = '$' + refTotal.toFixed(2);\r","            document.getElementById('s-fees').innerText = '$' + (permit + disposal).toFixed(2);\r","            document.getElementById('s-raw').innerText = '$' + rawCost.toFixed(2);\r","            document.getElementById('s-markup').innerText = '$' + markup.toFixed(2);\r","            document.getElementById('s-disc').innerText = '-$' + discount.toFixed(2);\r","            document.getElementById('s-fin').innerText = '$' + finFee.toFixed(2);\r","            document.getElementById('s-tax').innerText = '$' + tax.toFixed(2);\r","            document.getElementById('s-total').innerText = '$' + totalBid.toFixed(2);\r","            document.getElementById('footer-total').innerText = '$' + totalBid.toFixed(2);\r","\r","            // Tiers\r","            document.getElementById('t-good').innerHTML = '$' + totalBid.toFixed(2) + '<small>Standard Efficiency</small>';\r","            document.getElementById('t-better').innerHTML = '$' + (totalBid * 1.08).toFixed(2) + '<small>Mid Efficiency (+8%)</small>';\r","            document.getElementById('t-best').innerHTML = '$' + (totalBid * 1.18).toFixed(2) + '<small>High Efficiency (+18%)</small>';\r","\r","            // Sticky Bar\r","            if (window.updateMintStickyBar) {\r","                window.updateMintStickyBar({\r","                    'Bid Total': '$' + totalBid.toFixed(0),\r","                    'Profit': '$' + markup.toFixed(0)\r","                }, '/hvac-bid-calculator/');\r","            }\r","        }\r","\r","        function saveBid() {\r","            const logBody = document.getElementById('logBody');\r","            const placeholder = logBody.querySelector('tr[style*=\"italic\"]');\r","            if (placeholder) placeholder.remove();\r","\r","            const cust = document.getElementById('custName').value || 'Unknown';\r","            const est = document.getElementById('estNum').value || 'N/A';\r","            const date = document.getElementById('jobDate').value || new Date().toLocaleDateString();\r","            const amt = document.getElementById('s-total').innerText;\r","\r","            const row = document.createElement('tr');\r","            row.innerHTML = `<td>${cust}</td><td>${est}</td><td>${date}</td><td>${amt}</td><td>7 Days</td><td><span class=\\\"status-badge\\\" style=\\\"background:#FF9966\\\">Pending</span></td><td class=\\\"no-print\\\"><button class=\\\"btn btn-delete btn-sm\\\" onclick=\\\"this.closest(\\'tr\\').remove()\\\">✕</button></td>`;\r","            logBody.appendChild(row);\r","        }\r","\r","        function clearAll() {\r","            if (confirm('Clear all bid information?')) {\r","                location.reload();\r","            }\r","        }\r","    </script>\r","\r","    <!-- NAVIGATION SCRIPT -->\r","      <script>","  (function () {","    var btn = document.getElementById('hamburger-btn');","    var nav = document.getElementById('mobile-nav');","    var overlay = document.getElementById('mobile-nav-overlay');","    var close = document.getElementById('mobile-nav-close');","    if (!btn || !nav) return;","    function setMenuState(open) {","      document.body.classList.toggle('menu-open', open);","      btn.classList.toggle('active', open);","      btn.setAttribute('aria-expanded', open ? 'true' : 'false');","      nav.setAttribute('aria-hidden', open ? 'false' : 'true');","    }","    btn.addEventListener('click', function () { setMenuState(!btn.classList.contains('active')); });","    close && close.addEventListener('click', function () { setMenuState(false); });","    overlay && overlay.addEventListener('click', function () { setMenuState(false); });","    document.addEventListener('keydown', function (e) {","      if (e.key === 'Escape') setMenuState(false);","    });","  })();","  </script>\r","  <!-- Sticky Ad Placeholder -->\r","  <div class=\"ad-placeholder ad-placeholder-sticky\" id=\"sticky-ad\">\r","    <span>Advertisement</span>\r","    <button class=\"ad-sticky-close\" onclick=\"document.getElementById('sticky-ad').style.display='none'\" aria-label=\"Close Ad\">&times;</button>\r","  </div>\r","</body>\r","</html>\r","\r","\r","\r","\r",""]